# Backend API URL (used by Vite dev proxy — not needed in production)
# In production, the Flask server serves both the API and the dashboard,
# so requests go to the same origin.
VITE_API_BASE_URL=http://localhost:5001

# ── Flask Backend (set these on the server, not in this file) ──
# GEMINI_API_KEY=your-google-gemini-api-key
# BREVO_API_KEY=your-brevo-api-key
